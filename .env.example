# ==========================================
# LangSmith Observability & Tracing Config
# ==========================================

# Enable/disable LangSmith tracing (true/false)
LANGSMITH_TRACING=true

# LangSmith API endpoint
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# LangSmith API Key - Get from: https://smith.langchain.com → Settings → API Keys
LANGSMITH_API_KEY=lsv_<your-api-key-here>

# LangSmith project name for organizing traces
LANGSMITH_PROJECT=agents-pronunciation

# ==========================================
# Azure Speech Services Config
# ==========================================

AZURE_SPEECH_KEY=<your-azure-speech-key>
AZURE_SPEECH_REGION=eastus

# ==========================================
# OpenAI Config
# ==========================================

OPENAI_API_KEY=sk-<your-openai-api-key>

# ==========================================
# Database Config
# ==========================================

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/agents_db
PG_URI=postgresql://user:password@localhost:5432/agents_db

# ==========================================
# RabbitMQ Config (Message Broker)
# ==========================================

RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# ==========================================
# Chroma Vector DB Config
# ==========================================

CHROMA_COLLECTION_NAME=pronunciation-vectors
CHROMA_HOST=localhost
CHROMA_PORT=8000

# ==========================================
# Application Config
# ==========================================

LOG_LEVEL=INFO
ENVIRONMENT=development
